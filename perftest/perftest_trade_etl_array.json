        },
        {
            "name": "risk",
            "type": "perftest.array_trade_calculators.ArrayRiskScoreCalculator",
            "config": {}
        },
        {
            "name": "classify",
            "type": "perftest.array_trade_calculators.ArrayClassifyCalculator",
            "config": {}
        },

{
    "_comment": "Example: Consumer DAG on Worker 1 - receives data from Producer DAG on Worker 0",
    "_description": "Demonstrates cross-worker communication using LMDB pub/sub",
    
    "name": "cross_worker_consumer_dag",
    "version": "1.5.2",
    "priority": 7,
    
    "worker_affinity": {
        "pinned_worker": 1,
        "exclusive": false
    },
    
    "subscribers": [
        {
            "name": "cross_worker_subscriber",
            "config": {
                "source": "lmdb://producer_to_consumer",
                "lmdb_path": "data/worker_lmdb",
                "poll_interval_ms": 10,
                "max_depth": 10000,
                "auto_package_non_dict": true,
                "add_package_metadata": true
            }
        }
    ],
    
    "calculators": [
        {
            "name": "data_aggregator",
            "type": "PythonCalculator",
            "config": {
                "module": "example_calculators.aggregator",
                "class": "DataAggregator"
            }
        }
    ],
    
    "nodes": [
        {
            "name": "entry",
            "type": "subscriber",
            "subscriber": "cross_worker_subscriber"
        },
        {
            "name": "aggregate",
            "type": "calculator",
            "calculator": "data_aggregator"
        },
        {
            "name": "output",
            "type": "publisher",
            "publisher": "final_output"
        }
    ],
    
    "edges": [
        {"from": "entry", "to": "aggregate"},
        {"from": "aggregate", "to": "output"}
    ],
    
    "publishers": [
        {
            "name": "final_output",
            "config": {
                "destination": "mem://aggregated_results",
                "max_depth": 5000
            }
        }
    ]
}

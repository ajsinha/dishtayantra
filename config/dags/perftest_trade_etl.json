{
  "name": "perftest_trade_etl",
  "subscribers": [
    {
      "name": "trade_kafka",
      "config": {
        "source": "kafka://topic/perftest_trades",
        "bootstrap_servers": [
          "localhost:9092"
        ],
        "group_id": "perftest_trade_etl",
        "kafka_library": "kafka-python",
        "idle_poll_interval": 0.002,
        "_idle_note": "Low idle poll for a latency-sensitive benchmark feed."
      }
    }
  ],
  "publishers": [
    {
      "name": "output_file",
      "config": {
        "destination": "file:///tmp/perftest/trade_etl_output.jsonl"
      }
    },
    {
      "name": "output_kafka",
      "config": {
        "destination": "kafka://topic/perftest_trades_enriched",
        "bootstrap_servers": [
          "localhost:9092"
        ],
        "kafka_library": "kafka-python"
      }
    },
    {
      "name": "output_kafka_async",
      "config": {
        "destination": "kafka://topic/perftest_trades_enriched_async",
        "bootstrap_servers": [
          "localhost:9092"
        ],
        "kafka_library": "kafka-python",
        "async_egress": true,
        "_async_note": "async_egress:true routes this publisher through the WAL-backed AsyncPublisher (non-blocking publish) when the global switch egress.async.enabled=true is set. The sibling output_kafka stays inline, so you can benchmark async vs sync side by side."
      }
    }
  ],
  "calculators": [
    {
      "name": "validate",
      "type": "perftest.etl_calculators.ValidateTradeCalculator",
      "config": {}
    },
    {
      "name": "normalize",
      "type": "perftest.etl_calculators.NormalizeTradeCalculator",
      "config": {}
    },
    {
      "name": "fx",
      "type": "perftest.etl_calculators.FxConvertCalculator",
      "config": {
        "default_rate": 1
      }
    },
    {
      "name": "notional",
      "type": "perftest.etl_calculators.NotionalCalculator",
      "config": {}
    },
    {
      "name": "fees",
      "type": "perftest.etl_calculators.FeeCalculator",
      "config": {
        "commission_rate": 0.0005,
        "exchange_fee_rate": 0.0001,
        "min_fee": 0.5
      }
    },
    {
      "name": "risk",
      "type": "perftest.etl_calculators.RiskScoreCalculator",
      "config": {}
    },
    {
      "name": "anomaly",
      "type": "perftest.etl_calculators.AnomalyFlagCalculator",
      "config": {
        "fat_finger_qty": 1000000,
        "max_price_usd": 1000000
      }
    },
    {
      "name": "classify",
      "type": "perftest.etl_calculators.ClassifyTradeCalculator",
      "config": {}
    },
    {
      "name": "summarize",
      "type": "perftest.etl_calculators.SummarizeTradeCalculator",
      "config": {}
    }
  ],
  "transformers": [],
  "nodes": [
    {
      "name": "trade_ingest",
      "type": "SubscriptionNode",
      "config": {},
      "subscriber": "trade_kafka",
      "calculator": "validate"
    },
    {
      "name": "normalize_node",
      "type": "CalculationNode",
      "config": {},
      "calculator": "normalize"
    },
    {
      "name": "fx_node",
      "type": "CalculationNode",
      "config": {},
      "calculator": "fx"
    },
    {
      "name": "notional_node",
      "type": "CalculationNode",
      "config": {},
      "calculator": "notional"
    },
    {
      "name": "fees_branch",
      "type": "CalculationNode",
      "config": {},
      "calculator": "fees"
    },
    {
      "name": "risk_branch",
      "type": "CalculationNode",
      "config": {},
      "calculator": "risk"
    },
    {
      "name": "anomaly_branch",
      "type": "CalculationNode",
      "config": {},
      "calculator": "anomaly"
    },
    {
      "name": "classify_node",
      "type": "CalculationNode",
      "config": {},
      "calculator": "classify"
    },
    {
      "name": "summarize_node",
      "type": "CalculationNode",
      "config": {},
      "calculator": "summarize"
    },
    {
      "name": "file_sink",
      "type": "PublisherSinkNode",
      "config": {
        "publishers": [
          "output_file"
        ]
      }
    },
    {
      "name": "kafka_sink",
      "type": "PublisherSinkNode",
      "config": {
        "publishers": [
          "output_kafka"
        ]
      }
    },
    {
      "name": "kafka_async_sink",
      "type": "PublisherSinkNode",
      "config": {
        "publishers": [
          "output_kafka_async"
        ]
      }
    }
  ],
  "edges": [
    {
      "from_node": "trade_ingest",
      "to_node": "normalize_node"
    },
    {
      "from_node": "normalize_node",
      "to_node": "fx_node"
    },
    {
      "from_node": "fx_node",
      "to_node": "notional_node"
    },
    {
      "from_node": "notional_node",
      "to_node": "fees_branch"
    },
    {
      "from_node": "notional_node",
      "to_node": "risk_branch"
    },
    {
      "from_node": "notional_node",
      "to_node": "anomaly_branch"
    },
    {
      "from_node": "fees_branch",
      "to_node": "classify_node"
    },
    {
      "from_node": "risk_branch",
      "to_node": "classify_node"
    },
    {
      "from_node": "anomaly_branch",
      "to_node": "classify_node"
    },
    {
      "from_node": "classify_node",
      "to_node": "summarize_node"
    },
    {
      "from_node": "summarize_node",
      "to_node": "file_sink"
    },
    {
      "from_node": "summarize_node",
      "to_node": "kafka_sink"
    },
    {
      "from_node": "summarize_node",
      "to_node": "kafka_async_sink"
    }
  ]
}
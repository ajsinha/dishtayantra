{
  "_comment": "Example: Producer DAG on Worker 0 - sends data via LMDB to Consumer DAG on Worker 1",
  "_description": "Demonstrates cross-worker communication using LMDB pub/sub",
  "name": "cross_worker_producer_dag",
  "version": "1.5.2",
  "priority": 7,
  "worker_affinity": {
    "pinned_worker": 0,
    "exclusive": false
  },
  "subscribers": [
    {
      "name": "input_subscriber",
      "config": {
        "source": "mem://input_queue",
        "max_depth": 5000
      }
    }
  ],
  "calculators": [
    {
      "name": "data_transformer",
      "type": "PythonCalculator",
      "config": {
        "module": "example_calculators.transformer",
        "class": "DataTransformer"
      }
    }
  ],
  "nodes": [
    {
      "name": "entry",
      "type": "SubscriptionNode",
      "subscriber": "input_subscriber"
    },
    {
      "name": "transform",
      "type": "CalculationNode",
      "calculator": "data_transformer"
    },
    {
      "name": "output",
      "type": "PublicationNode",
      "publisher": "cross_worker_publisher"
    }
  ],
  "edges": [
    {
      "from": "entry",
      "to": "transform"
    },
    {
      "from": "transform",
      "to": "output"
    }
  ],
  "publishers": [
    {
      "name": "cross_worker_publisher",
      "config": {
        "destination": "lmdb://producer_to_consumer",
        "lmdb_path": "data/worker_lmdb",
        "map_size_mb": 512
      }
    }
  ]
}
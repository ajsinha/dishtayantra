{
  "_comment": "C++ trade pricing pipeline (pybind11). Requires the native dishtayantra_cpp module to RUN. Migrated to current schema.",
  "name": "cpp_trade_pricing_dag",
  "description": "Trade validate -> price -> risk pipeline using C++ calculators.",
  "version": "2.0",
  "start_time": null,
  "duration": null,
  "subscribers": [
    {
      "name": "trade_feed",
      "config": {
        "source": "mem://queue/cpp_trades_input"
      }
    }
  ],
  "publishers": [
    {
      "name": "priced_out",
      "config": {
        "destination": "mem://topic/cpp_priced_trades"
      }
    }
  ],
  "calculators": [
    {
      "name": "validate_trade",
      "type": "cpp",
      "config": {
        "cpp_class": "DataValidationCalculator",
        "cpp_module": "dishtayantra_cpp",
        "strict_mode": false,
        "validate_types": true,
        "required_fields": [
          "price",
          "quantity",
          "symbol"
        ]
      }
    },
    {
      "name": "price_trade",
      "type": "cpp",
      "config": {
        "cpp_class": "TradePricingCalculator",
        "cpp_module": "dishtayantra_cpp",
        "commission_rate": 0.001,
        "tax_rate": 0.0,
        "include_fees": true
      }
    },
    {
      "name": "calculate_risk",
      "type": "cpp",
      "config": {
        "cpp_class": "RiskMetricsCalculator",
        "cpp_module": "dishtayantra_cpp",
        "var_confidence": 0.95,
        "risk_free_rate": 0.02
      }
    }
  ],
  "transformers": [],
  "nodes": [
    {
      "name": "trade_in",
      "type": "SubscriptionNode",
      "subscriber": "trade_feed",
      "calculator": "validate_trade",
      "config": {}
    },
    {
      "name": "price_node",
      "type": "CalculationNode",
      "calculator": "price_trade",
      "config": {}
    },
    {
      "name": "risk_node",
      "type": "CalculationNode",
      "calculator": "calculate_risk",
      "config": {}
    },
    {
      "name": "results_sink",
      "type": "PublisherSinkNode",
      "config": {
        "publishers": [
          "priced_out"
        ]
      }
    }
  ],
  "edges": [
    {
      "from_node": "trade_in",
      "to_node": "price_node"
    },
    {
      "from_node": "price_node",
      "to_node": "risk_node"
    },
    {
      "from_node": "risk_node",
      "to_node": "results_sink"
    }
  ]
}
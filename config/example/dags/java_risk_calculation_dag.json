{
  "_comment": "Portfolio risk pipeline (Py4J). Requires py4j + dishtayantra-calculators.jar + jvm_manager to RUN. The original inline 'condition' on the alerts sink is not part of the node schema and was dropped; gate alerts with a calculator if needed. Migrated to current schema.",
  "name": "java_risk_calculation_dag",
  "description": "VaR -> aggregate risk pipeline using Java calculators, with a parallel alerts sink.",
  "version": "2.0",
  "start_time": null,
  "duration": null,
  "subscribers": [
    {
      "name": "positions_feed",
      "config": {
        "source": "mem://queue/positions_input"
      }
    }
  ],
  "publishers": [
    {
      "name": "risk_out",
      "config": {
        "destination": "mem://topic/risk_output"
      }
    },
    {
      "name": "alerts_out",
      "config": {
        "destination": "mem://topic/risk_alerts"
      }
    }
  ],
  "calculators": [
    {
      "name": "calculate_var",
      "type": "java",
      "config": {
        "java_class": "com.dishtayantra.calculators.examples.ExampleCalculators$RiskCalculator",
        "gateway_config": {
          "gateway": "primary"
        },
        "var_confidence": 0.99,
        "lookback_period": 252
      }
    },
    {
      "name": "aggregate_risk",
      "type": "java",
      "config": {
        "java_class": "com.dishtayantra.calculators.examples.ExampleCalculators$AggregationCalculator",
        "gateway_config": {
          "gateway": "primary"
        },
        "aggregate_field": "daily_var",
        "aggregate_type": "all"
      }
    }
  ],
  "transformers": [],
  "nodes": [
    {
      "name": "positions_in",
      "type": "SubscriptionNode",
      "subscriber": "positions_feed",
      "calculator": "calculate_var",
      "config": {}
    },
    {
      "name": "aggregate_node",
      "type": "CalculationNode",
      "calculator": "aggregate_risk",
      "config": {}
    },
    {
      "name": "risk_sink",
      "type": "PublisherSinkNode",
      "config": {
        "publishers": [
          "risk_out"
        ]
      }
    },
    {
      "name": "alerts_sink",
      "type": "PublisherSinkNode",
      "config": {
        "publishers": [
          "alerts_out"
        ]
      }
    }
  ],
  "edges": [
    {
      "from_node": "positions_in",
      "to_node": "aggregate_node"
    },
    {
      "from_node": "aggregate_node",
      "to_node": "risk_sink"
    },
    {
      "from_node": "positions_in",
      "to_node": "alerts_sink"
    }
  ]
}
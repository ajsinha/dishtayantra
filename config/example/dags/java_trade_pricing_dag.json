{
  "_comment": "Java trade pricing pipeline (Py4J). Java steps require py4j + dishtayantra-calculators.jar + jvm_manager to RUN. The final timestamp step is a built-in Python PassthruCalculator (was an example timestamp calculator). Migrated to current schema.",
  "name": "java_trade_pricing_dag",
  "description": "Validate -> price -> timestamp pipeline using Java calculators.",
  "version": "2.0",
  "start_time": null,
  "duration": null,
  "subscribers": [
    {
      "name": "trade_feed",
      "config": {
        "source": "mem://queue/java_trades_input"
      }
    }
  ],
  "publishers": [
    {
      "name": "priced_out",
      "config": {
        "destination": "mem://topic/java_trades_priced"
      }
    }
  ],
  "calculators": [
    {
      "name": "validate_trade",
      "type": "java",
      "config": {
        "java_class": "com.dishtayantra.calculators.examples.ExampleCalculators$DataValidationCalculator",
        "gateway_config": {
          "gateway": "primary"
        },
        "strict_mode": false,
        "required_fields": [
          "symbol",
          "price",
          "quantity",
          "side"
        ]
      }
    },
    {
      "name": "calculate_pricing",
      "type": "java",
      "config": {
        "java_class": "com.dishtayantra.calculators.examples.ExampleCalculators$TradePricingCalculator",
        "gateway_config": {
          "gateway": "primary"
        },
        "commission_rate": 0.001,
        "tax_rate": 0.002,
        "include_vat": true
      }
    },
    {
      "name": "add_timestamp",
      "type": "PassthruCalculator",
      "config": {
        "timestamp_field": "processed_at",
        "format": "iso"
      }
    }
  ],
  "transformers": [],
  "nodes": [
    {
      "name": "trade_in",
      "type": "SubscriptionNode",
      "subscriber": "trade_feed",
      "calculator": "validate_trade",
      "config": {}
    },
    {
      "name": "pricing_node",
      "type": "CalculationNode",
      "calculator": "calculate_pricing",
      "config": {}
    },
    {
      "name": "timestamp_node",
      "type": "CalculationNode",
      "calculator": "add_timestamp",
      "config": {}
    },
    {
      "name": "priced_sink",
      "type": "PublisherSinkNode",
      "config": {
        "publishers": [
          "priced_out"
        ]
      }
    }
  ],
  "edges": [
    {
      "from_node": "trade_in",
      "to_node": "pricing_node"
    },
    {
      "from_node": "pricing_node",
      "to_node": "timestamp_node"
    },
    {
      "from_node": "timestamp_node",
      "to_node": "priced_sink"
    }
  ]
}
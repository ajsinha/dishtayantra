{
  "_comment": "Rust time-series pipeline (PyO3). Requires the native dishtayantra_rust module to RUN. Migrated to current schema.",
  "name": "rust_timeseries_analysis_dag",
  "description": "Time-series pipeline: validate -> hash -> SMA -> json, using Rust calculators.",
  "version": "2.0",
  "start_time": null,
  "duration": null,
  "subscribers": [
    {
      "name": "ts_feed",
      "config": {
        "source": "mem://queue/rust_timeseries_input"
      }
    }
  ],
  "publishers": [
    {
      "name": "results_pub",
      "config": {
        "destination": "mem://topic/rust_timeseries_results"
      }
    }
  ],
  "calculators": [
    {
      "name": "validate_data",
      "type": "rust",
      "config": {
        "rust_class": "RustDataValidationCalculator",
        "rust_module": "dishtayantra_rust",
        "strict_mode": false,
        "required_fields": [
          "timestamp",
          "value"
        ]
      }
    },
    {
      "name": "hash_key",
      "type": "rust",
      "config": {
        "rust_class": "RustHashCalculator",
        "rust_module": "dishtayantra_rust",
        "algorithm": "xxhash"
      }
    },
    {
      "name": "ts_analysis",
      "type": "rust",
      "config": {
        "rust_class": "RustTimeSeriesCalculator",
        "rust_module": "dishtayantra_rust",
        "window_size": 20,
        "operation": "sma"
      }
    },
    {
      "name": "json_transform",
      "type": "rust",
      "config": {
        "rust_class": "RustJsonCalculator",
        "rust_module": "dishtayantra_rust",
        "operation": "format",
        "pretty": true
      }
    }
  ],
  "transformers": [],
  "nodes": [
    {
      "name": "ts_in",
      "type": "SubscriptionNode",
      "subscriber": "ts_feed",
      "calculator": "validate_data",
      "config": {}
    },
    {
      "name": "hash_node",
      "type": "CalculationNode",
      "calculator": "hash_key",
      "config": {}
    },
    {
      "name": "analysis_node",
      "type": "CalculationNode",
      "calculator": "ts_analysis",
      "config": {}
    },
    {
      "name": "transform_node",
      "type": "CalculationNode",
      "calculator": "json_transform",
      "config": {}
    },
    {
      "name": "results_sink",
      "type": "PublisherSinkNode",
      "config": {
        "publishers": [
          "results_pub"
        ]
      }
    }
  ],
  "edges": [
    {
      "from_node": "ts_in",
      "to_node": "hash_node"
    },
    {
      "from_node": "hash_node",
      "to_node": "analysis_node"
    },
    {
      "from_node": "analysis_node",
      "to_node": "transform_node"
    },
    {
      "from_node": "transform_node",
      "to_node": "results_sink"
    }
  ]
}
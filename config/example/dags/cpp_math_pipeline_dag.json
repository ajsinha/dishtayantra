{
  "_comment": "C++ MathCalculator pipeline (pybind11). Requires the native dishtayantra_cpp module (cd cpp && cmake .. && make) to RUN; without it the DAG validates/deploys but the calculators fail to load at start. Migrated to current schema.",
  "name": "cpp_math_pipeline",
  "description": "Math pipeline using C++ calculators (sum -> mean -> variance).",
  "version": "2.0",
  "start_time": null,
  "duration": null,
  "subscribers": [
    {
      "name": "math_feed",
      "config": {
        "source": "mem://queue/cpp_math_input"
      }
    }
  ],
  "publishers": [
    {
      "name": "results_pub",
      "config": {
        "destination": "mem://topic/cpp_math_results"
      }
    }
  ],
  "calculators": [
    {
      "name": "sum_calc",
      "type": "cpp",
      "config": {
        "cpp_class": "MathCalculator",
        "cpp_module": "dishtayantra_cpp",
        "operation": "sum",
        "precision": 6
      }
    },
    {
      "name": "mean_calc",
      "type": "cpp",
      "config": {
        "cpp_class": "MathCalculator",
        "cpp_module": "dishtayantra_cpp",
        "operation": "mean",
        "precision": 6
      }
    },
    {
      "name": "variance_calc",
      "type": "cpp",
      "config": {
        "cpp_class": "StatisticsCalculator",
        "cpp_module": "dishtayantra_cpp",
        "compute_percentiles": true,
        "percentile_values": [
          50,
          90,
          95
        ]
      }
    }
  ],
  "transformers": [],
  "nodes": [
    {
      "name": "math_in",
      "type": "SubscriptionNode",
      "subscriber": "math_feed",
      "calculator": "sum_calc",
      "config": {}
    },
    {
      "name": "mean_node",
      "type": "CalculationNode",
      "calculator": "mean_calc",
      "config": {}
    },
    {
      "name": "variance_node",
      "type": "CalculationNode",
      "calculator": "variance_calc",
      "config": {}
    },
    {
      "name": "results_sink",
      "type": "PublisherSinkNode",
      "config": {
        "publishers": [
          "results_pub"
        ]
      }
    }
  ],
  "edges": [
    {
      "from_node": "math_in",
      "to_node": "mean_node"
    },
    {
      "from_node": "mean_node",
      "to_node": "variance_node"
    },
    {
      "from_node": "variance_node",
      "to_node": "results_sink"
    }
  ]
}
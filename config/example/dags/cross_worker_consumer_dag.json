{
  "_comment": "Example: Consumer DAG on Worker 1 - receives data from Producer DAG on Worker 0",
  "_description": "Demonstrates cross-worker communication using LMDB pub/sub",
  "name": "cross_worker_consumer_dag",
  "version": "1.5.2",
  "priority": 7,
  "worker_affinity": {
    "pinned_worker": 1,
    "exclusive": false
  },
  "subscribers": [
    {
      "name": "cross_worker_subscriber",
      "config": {
        "source": "lmdb://producer_to_consumer",
        "lmdb_path": "data/worker_lmdb",
        "poll_interval_ms": 10,
        "max_depth": 10000,
        "auto_package_non_dict": true,
        "add_package_metadata": true
      }
    }
  ],
  "calculators": [
    {
      "name": "data_aggregator",
      "type": "PassthruCalculator",
      "config": {}
    }
  ],
  "nodes": [
    {
      "name": "entry",
      "type": "SubscriptionNode",
      "subscriber": "cross_worker_subscriber"
    },
    {
      "name": "aggregate",
      "type": "CalculationNode",
      "calculator": "data_aggregator"
    },
    {
      "name": "output",
      "type": "PublicationNode",
      "publisher": "final_output"
    }
  ],
  "edges": [
    {
      "from_node": "entry",
      "to_node": "aggregate"
    },
    {
      "from_node": "aggregate",
      "to_node": "output"
    }
  ],
  "publishers": [
    {
      "name": "final_output",
      "config": {
        "destination": "mem://aggregated_results",
        "max_depth": 5000
      }
    }
  ],
  "_calculator_note": "Calculators repointed from fictional example_calculators/* classes to the built-in PassthruCalculator so this example builds and clones out-of-the-box. Replace 'type' with your own dotted-path calculator (module.ClassName) to do real work."
}
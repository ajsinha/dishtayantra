{
  "_comment": "Hybrid Python+Java math pipeline (Py4J). Java steps require py4j + the compiled dishtayantra-calculators.jar + jvm_manager enabled to RUN. The first step is a built-in Python PassthruCalculator (was an example preprocessing step). Migrated to current schema.",
  "name": "java_math_hybrid_dag",
  "description": "Python normalize -> Java sum -> Java multiply -> Java string-transform.",
  "version": "2.0",
  "start_time": null,
  "duration": null,
  "subscribers": [
    {
      "name": "math_feed",
      "config": {
        "source": "mem://queue/java_math_input"
      }
    }
  ],
  "publishers": [
    {
      "name": "math_out",
      "config": {
        "destination": "mem://topic/java_math_output"
      }
    }
  ],
  "calculators": [
    {
      "name": "normalize",
      "type": "PassthruCalculator",
      "config": {
        "add_metadata": true
      }
    },
    {
      "name": "java_sum",
      "type": "java",
      "config": {
        "java_class": "com.dishtayantra.calculators.examples.ExampleCalculators$MathCalculator",
        "gateway_config": {
          "gateway": "primary"
        },
        "operation": "sum",
        "arguments": [
          "value1",
          "value2",
          "value3"
        ],
        "output_attribute": "total"
      }
    },
    {
      "name": "java_multiply",
      "type": "java",
      "config": {
        "java_class": "com.dishtayantra.calculators.examples.ExampleCalculators$MathCalculator",
        "gateway_config": {
          "gateway": "primary"
        },
        "operation": "multiply",
        "arguments": [
          "total",
          "multiplier"
        ],
        "output_attribute": "final_result"
      }
    },
    {
      "name": "java_transform",
      "type": "java",
      "config": {
        "java_class": "com.dishtayantra.calculators.examples.ExampleCalculators$StringTransformCalculator",
        "gateway_config": {
          "gateway": "primary"
        },
        "operation": "uppercase",
        "source_field": "label",
        "target_field": "label_upper"
      }
    }
  ],
  "transformers": [],
  "nodes": [
    {
      "name": "math_in",
      "type": "SubscriptionNode",
      "subscriber": "math_feed",
      "calculator": "normalize",
      "config": {}
    },
    {
      "name": "sum_node",
      "type": "CalculationNode",
      "calculator": "java_sum",
      "config": {}
    },
    {
      "name": "multiply_node",
      "type": "CalculationNode",
      "calculator": "java_multiply",
      "config": {}
    },
    {
      "name": "transform_node",
      "type": "CalculationNode",
      "calculator": "java_transform",
      "config": {}
    },
    {
      "name": "results_sink",
      "type": "PublisherSinkNode",
      "config": {
        "publishers": [
          "math_out"
        ]
      }
    }
  ],
  "edges": [
    {
      "from_node": "math_in",
      "to_node": "sum_node"
    },
    {
      "from_node": "sum_node",
      "to_node": "multiply_node"
    },
    {
      "from_node": "multiply_node",
      "to_node": "transform_node"
    },
    {
      "from_node": "transform_node",
      "to_node": "results_sink"
    }
  ]
}
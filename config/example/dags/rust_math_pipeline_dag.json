{
  "_comment": "Rust math pipeline (PyO3). Requires the native dishtayantra_rust module (cd rust && maturin develop --release) to RUN. Migrated to current schema.",
  "name": "rust_math_pipeline_dag",
  "description": "Math pipeline using Rust calculators (sum -> mean -> stats).",
  "version": "2.0",
  "start_time": null,
  "duration": null,
  "subscribers": [
    {
      "name": "math_feed",
      "config": {
        "source": "mem://queue/rust_math_input"
      }
    }
  ],
  "publishers": [
    {
      "name": "results_pub",
      "config": {
        "destination": "mem://topic/rust_math_results"
      }
    }
  ],
  "calculators": [
    {
      "name": "sum_calc",
      "type": "rust",
      "config": {
        "rust_class": "RustMathCalculator",
        "rust_module": "dishtayantra_rust",
        "operation": "sum",
        "precision": 8
      }
    },
    {
      "name": "mean_calc",
      "type": "rust",
      "config": {
        "rust_class": "RustMathCalculator",
        "rust_module": "dishtayantra_rust",
        "operation": "mean"
      }
    },
    {
      "name": "stats_calc",
      "type": "rust",
      "config": {
        "rust_class": "RustStatisticsCalculator",
        "rust_module": "dishtayantra_rust",
        "compute_percentiles": true,
        "percentile_values": [
          25,
          50,
          75,
          90,
          95,
          99
        ]
      }
    }
  ],
  "transformers": [],
  "nodes": [
    {
      "name": "math_in",
      "type": "SubscriptionNode",
      "subscriber": "math_feed",
      "calculator": "sum_calc",
      "config": {}
    },
    {
      "name": "mean_node",
      "type": "CalculationNode",
      "calculator": "mean_calc",
      "config": {}
    },
    {
      "name": "stats_node",
      "type": "CalculationNode",
      "calculator": "stats_calc",
      "config": {}
    },
    {
      "name": "results_sink",
      "type": "PublisherSinkNode",
      "config": {
        "publishers": [
          "results_pub"
        ]
      }
    }
  ],
  "edges": [
    {
      "from_node": "math_in",
      "to_node": "mean_node"
    },
    {
      "from_node": "mean_node",
      "to_node": "stats_node"
    },
    {
      "from_node": "stats_node",
      "to_node": "results_sink"
    }
  ]
}
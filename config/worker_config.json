{
    "_comment": "DishtaYantra Worker Pool Configuration - v1.5.2",
    "_description": "Configure multiprocessing worker pool for DAG execution with CPU affinity",
    
    "worker_pool": {
        "enabled": false,
        "_enabled_note": "Set to true to enable worker pool multiprocessing. Default is false (single-process mode).",
        "num_workers": 4,
        "_num_workers_note": "Default is 4. Can also be set via application.properties: worker.pool.num_workers",
        
        "min_workers": 2,
        "max_workers": 32,
        
        "worker_startup_timeout_seconds": 30,
        "worker_shutdown_timeout_seconds": 10,
        "worker_stabilization_seconds": 10,
        "_worker_stabilization_note": "Wait time after workers report ready before dispatching DAGs. Allows workers to complete module imports and setup.",
        
        "health_check_interval_seconds": 5,
        "status_report_interval_seconds": 2,
        
        "auto_restart_on_crash": true,
        "max_restart_attempts": 3,
        "restart_backoff_seconds": 5
    },
    
    "affinity": {
        "default_strategy": "weight_based",
        "_strategies": ["round_robin", "weight_based", "least_loaded", "random"],
        
        "rebalance_enabled": true,
        "rebalance_threshold": 0.3,
        "rebalance_interval_seconds": 60,
        
        "allow_dag_pinning": true,
        "allow_exclusive_workers": true
    },
    
    "communication": {
        "control_queue_maxsize": 1000,
        "status_queue_maxsize": 5000,
        
        "use_lmdb_for_cross_worker": true,
        "lmdb_path": "data/worker_lmdb",
        "lmdb_map_size_mb": 1024
    },
    
    "monitoring": {
        "collect_cpu_metrics": true,
        "collect_memory_metrics": true,
        "collect_dag_metrics": true,
        "metrics_history_size": 1000
    },
    
    "defaults": {
        "dag_cpu_weight": 0.2,
        "dag_priority": 5
    }
}
